BOT_TOKEN=your_telegram_bot_token
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-5.4-mini
INTENT_MODEL=gpt-5.4-nano
ADMIN_ID=123456789
KEYN_DATABASE_PATH=./keyn_start_database.txt
KEYN_BONUS_DATABASE_PATH=./keyn_bonus_database.txt
ASSISTANT_STYLE=Говори как Кейн: ясно, сдержанно, немного иронично, но всегда доброжелательно и в рамках мира Риммэля.

# Optional on Railway:
# If you attach a volume, the app will automatically use RAILWAY_VOLUME_MOUNT_PATH.
# You only need the variables below if you want to override the storage paths manually.
# DATABASE_PATH=/app/data/app.db
# CHROMA_PATH=/app/data/chroma_db
# UPLOAD_PATH=/app/data/uploads

CHROMA_COLLECTION=knowledge_base
EMBEDDING_MODEL=text-embedding-3-small
CHAT_MODEL=gpt-5.4-mini
CHUNK_SIZE=500
CHUNK_OVERLAP=100
TOP_K=5
SIMILARITY_THRESHOLD=0.6
